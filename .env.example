# Agents on Lightning — environment variables

# Server port (default: 3200)
PORT=3200

# Additional CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com

# Anthropic API key (for /api/v1/help endpoint)
# Can also be stored at ~/.config/anthropic/api_key
# ANTHROPIC_API_KEY=sk-ant-...
