NODE_ENV=production
AOL_SERVER_ROLE=prod
AOL_CONFIG_PATH=APP_CONFIG_DIR/config.yaml
AOL_DATA_DIR=APP_DATA_DIR
AOL_JOURNEY_DB_PATH=APP_DATA_DIR/data/journey-analytics.duckdb
AOL_EXTERNAL_ACCESS_MODE=mcp_only
AOL_INTERNAL_BASE_URL=http://127.0.0.1:APP_PORT
HOST=APP_HOST
PORT=APP_PORT
TRUST_PROXY=1
PYTHON3=/usr/bin/python3

# Optional secrets and allowlists:
# AOL_INTERNAL_MCP_SECRET=... # generated automatically if omitted
# ENABLE_OPERATOR_ROUTES=0
# ANTHROPIC_API_KEY=...
# ANTHROPIC_API_KEY_FILE=PRIVATE_PATH
# OPERATOR_API_SECRET=...
# CORS_ORIGINS=https://PRIMARY_DOMAIN,https://www.PRIMARY_DOMAIN
# CHANNEL_OPEN_PEER_ALLOWLIST=...
# CHANNEL_OPEN_REQUIRE_PEER_ALLOWLIST=1
# AOL_LND_MAX_SOCKETS=64
# AOL_LND_MAX_FREE_SOCKETS=8
# AOL_LND_KEEP_ALIVE_MS=10000
