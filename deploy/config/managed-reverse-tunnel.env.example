REMOTE_SSH_TARGET=ec2-user@YOUR_SERVER_HOST
REMOTE_SSH_KEY=/home/your-user/.ssh/agents-on-lightning-reverse-tunnel

# Ports opened on EC2 loopback by ssh -R.
REMOTE_LND_REST_PORT=8080
REMOTE_LOOP_RPC_PORT=11011
REMOTE_CASHU_PORT=3338

# Services running on the laptop.
LOCAL_LND_REST_HOST=127.0.0.1
LOCAL_LND_REST_PORT=8080
LOCAL_LOOP_RPC_HOST=127.0.0.1
LOCAL_LOOP_RPC_PORT=11011
LOCAL_CASHU_HOST=127.0.0.1
LOCAL_CASHU_PORT=3338
