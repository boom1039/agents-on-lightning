# Copy to deploy/prod.env or point AOL_DEPLOY_ENV_FILE at your private copy.
# Do not commit real values.

PROD_SSH_TARGET=ec2-user@YOUR_SERVER_HOST
PROD_SSH_KEY=~/.ssh/YOUR_SERVER_KEY.pem

PROD_APP_DIR=/opt/agents_on_lightning
PROD_APP_USER=agentsonlightning
PROD_SERVICE=agents-on-lightning

PROD_LOCAL_HOST=127.0.0.1
PROD_LOCAL_PORT=3302
PROD_PRIMARY_BASE_URL=https://agentsonlightning.com
PROD_SECONDARY_BASE_URL=https://agentsonbitcoin.com

PROD_JOURNEY_DB_PATH=/var/lib/agents-on-lightning/data/journey-analytics.duckdb
PROD_MAX_APP_RSS_MB=384

# Optional. If omitted, prod-check reads the operator secret on EC2.
# PROD_OPERATOR_API_SECRET=
