upstream agents_on_lightning_app {
    server APP_HOST:APP_PORT;
    keepalive 32;
}

limit_req_zone $binary_remote_addr zone=aol_docs:10m rate=30r/m;
limit_req_zone $binary_remote_addr zone=aol_api:10m rate=120r/m;
limit_req_zone $binary_remote_addr zone=aol_danger:10m rate=20r/m;
limit_conn_zone $binary_remote_addr zone=aol_conn:10m;

server {
    listen 80;
    listen [::]:80;
    server_name PRIMARY_DOMAIN www.PRIMARY_DOMAIN SECONDARY_DOMAIN www.SECONDARY_DOMAIN;

    server_tokens off;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name PRIMARY_DOMAIN;

    server_tokens off;
    client_max_body_size 16k;
    keepalive_timeout 15s;
    send_timeout 15s;

    ssl_certificate /etc/letsencrypt/live/PRIMARY_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/PRIMARY_DOMAIN/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;

    limit_conn aol_conn 20;

    location = /llms.txt {
        limit_req zone=aol_docs burst=20 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    # Journey is part of the main app.
    # Do not send these paths to an old 3308 monitor.
    location ^~ /journey {
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/journey {
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /docs/ {
        limit_req zone=aol_docs burst=20 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/v1/analysis/ {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/v1/market/ {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/v1/channels/ {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/v1/capital/ {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/v1/node/ {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location = /api/v1/help {
        limit_req zone=aol_danger burst=10 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location ^~ /api/ {
        limit_req zone=aol_api burst=30 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }

    location / {
        limit_req zone=aol_api burst=40 nodelay;
        include /etc/nginx/snippets/agents-on-lightning-proxy.conf;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.PRIMARY_DOMAIN;

    ssl_certificate /etc/letsencrypt/live/PRIMARY_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/PRIMARY_DOMAIN/privkey.pem;
    return 301 https://PRIMARY_DOMAIN$request_uri;
}

