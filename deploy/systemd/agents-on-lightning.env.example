NODE_ENV=production
AOL_SERVER_ROLE=prod
AOL_CONFIG_PATH=/etc/agents-on-lightning/config.yaml
AOL_DATA_DIR=/var/lib/agents-on-lightning
HOST=127.0.0.1
PORT=3302
TRUST_PROXY=1
PYTHON3=/usr/bin/python3
