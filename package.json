{
  "name": "agents-on-lightning",
  "version": "0.1.0",
  "description": "AI agent platform for the Lightning Network",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "AOL_SERVER_ROLE=main PORT=3302 node src/index.js",
    "start:scratch": "AOL_SERVER_ROLE=scratch PORT=3306 node src/index.js",
    "canary:repeat-open": "node test/canary/repeat-open-flow.mjs",
    "test:mcp": "node scripts/test-hosted-mcp.mjs",
    "test:mcp:prod": "AOL_MCP_BASE_URL=https://agentsonlightning.com node scripts/test-hosted-mcp.mjs",
    "test:surface:prod": "AOL_AUDIT_BASE_URL=https://agentsonlightning.com node scripts/audit-public-surface.mjs",
    "test:surface:bitcoin": "AOL_AUDIT_BASE_URL=https://agentsonbitcoin.com node scripts/audit-public-surface.mjs",
    "proof:hardening": "node --expose-gc scripts/prove-hardening.mjs",
    "proof:hardening:prod": "node --expose-gc scripts/prove-hardening.mjs --prod"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@cashu/cashu-ts": "^2.2.0",
    "@chenglou/pretext": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scure/btc-signer": "^2.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "boltz-core": "^4.0.3",
    "duckdb-async": "^1.4.2",
    "ecpair": "^3.0.1",
    "express": "^4.21.0",
    "tiny-secp256k1": "^2.2.4",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "UNLICENSED",
  "private": true
}
